# ── Auth0 (SDK v4) ──────────────────────────────────────────────
# Preencha depois de criar o tenant. Passo a passo: AUTH0_SETUP.md
AUTH0_DOMAIN=seu-tenant.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=                      # gere com: openssl rand -hex 32
APP_BASE_URL=http://localhost:3000 # prod: https://app.uselaplace.co

# ── Management API (listar organizações; admin vê todas) ─────────
# App Machine-to-Machine autorizado na Auth0 Management API
AUTH0_MGMT_CLIENT_ID=
AUTH0_MGMT_CLIENT_SECRET=

# ── Admin ───────────────────────────────────────────────────────
# e-mails que enxergam TODAS as orgs (csv). Provisório até roles no token.
LAPLACE_ADMIN_EMAILS=finettogs@gmail.com

# ── Banco de metadados (Postgres) ───────────────────────────────
# Dev: Postgres local via Docker (docker-compose.yml na raiz).
# Prod (Vercel): Neon — mesma string, só muda o host.
DATABASE_URL=postgresql://laplace:laplace@localhost:5432/laplace
